generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  active
  inactive
  suspended
}

enum TenantPlan {
  basic
  pro
  enterprise
}

enum UserRole {
  superadmin
  admin
  cashier
}

enum SaleStatus {
  completed
  cancelled
}

enum ShiftStatus {
  open
  closed
}

enum CouponType {
  flat
  percentage
}

enum SupplierStatus {
  active
  inactive
}

enum PurchaseOrderStatus {
  draft
  sent
  partially_received
  received
  cancelled
}

enum ExpenseCategory {
  Rent
  Utilities
  Salaries
  Supplies
  Maintenance
  Marketing
  Other
}

enum ExpensePaymentMethod {
  cash
  card
  wallet
}

enum TableStatus {
  available
  occupied
  bill_printed
  split
}

enum OrderStatus {
  open
  billed
  paid
  cancelled
}

enum KotStatus {
  pending
  cooking
  ready
  served
  billed
}

enum ItemStatus {
  pending
  cooking
  ready
  served
  cancelled
}

enum LoyaltyTxType {
  earn
  redeem
  expire
  reverse
}

enum SplitType {
  equal
  by_item
  by_amount
}

enum CashMovementType {
  cash_in
  cash_out
}

enum StoreMode {
  retail
  restaurant
}

model Tenant {
  id         Int          @id @default(autoincrement())
  name       String
  email      String       @unique
  slug       String       @unique
  status     TenantStatus @default(active)
  plan       TenantPlan   @default(basic)
  created_at DateTime     @default(now())

  users             User[]
  products          Product[]
  customers         Customer[]
  sales             Sale[]
  shifts            Shift[]
  settings          Settings?
  coupons           Coupon[]
  notifications     Notification[]
  suppliers         Supplier[]
  purchase_orders   PurchaseOrder[]
  expenses          Expense[]
  restaurant_tables RestaurantTable[]
  restaurant_orders RestaurantOrder[]

  @@map("tenants")
}

model User {
  id             Int       @id @default(autoincrement())
  name           String
  email          String    @unique
  password       String
  role           UserRole  @default(cashier)
  permissions    String    @default("[]")
  failedAttempts Int       @default(0)
  lockUntil      DateTime?
  created_at     DateTime  @default(now())
  tenant_id      Int?

  tenant            Tenant?           @relation(fields: [tenant_id], references: [id])
  sales             Sale[]            @relation("CashierSales")
  shifts            Shift[]
  expenses          Expense[]
  restaurant_orders RestaurantOrder[]

  @@map("users")
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String
  category      String?
  sku           String?
  barcode       String?
  description   String?
  selling_price Decimal  @default(0) @db.Decimal(10, 2)
  cost_price    Decimal  @default(0) @db.Decimal(10, 2)
  stock         Int      @default(0)
  threshold     Int      @default(5)
  unit_type     String   @default("pcs")
  image         String?
  is_deleted    Boolean  @default(false)
  created_at    DateTime @default(now())
  tenant_id     Int

  tenant                 Tenant                @relation(fields: [tenant_id], references: [id])
  sale_items             SaleItem[]
  sale_return_items      SaleReturnItem[]
  product_variants       ProductVariant[]
  supplier_items         SupplierItem[]
  purchase_order_items   PurchaseOrderItem[]
  restaurant_order_items RestaurantOrderItem[]
  notifications          Notification[]

  @@map("products")
}

model ProductVariant {
  id         Int     @id @default(autoincrement())
  product_id Int
  name       String
  price      Decimal @default(0) @db.Decimal(10, 2)
  is_active  Boolean @default(true)
  sort_order Int     @default(0)

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_variants")
}

model Customer {
  id              Int      @id @default(autoincrement())
  customer_number Int      @default(0)
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  pincode         String?
  gst_number      String?
  loyalty_points  Int      @default(0)
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())
  tenant_id       Int

  tenant               Tenant               @relation(fields: [tenant_id], references: [id])
  sales                Sale[]
  loyalty_transactions LoyaltyTransaction[]

  @@map("customers")
}

model Sale {
  id                      Int        @id @default(autoincrement())
  sale_number             Int        @default(0)
  customer_id             Int?
  cashier_id              Int?
  shift_id                Int?
  coupon_id               Int?
  total                   Decimal    @default(0) @db.Decimal(10, 2)
  discount                Decimal    @default(0) @db.Decimal(10, 2)
  coupon_discount         Decimal    @default(0) @db.Decimal(10, 2)
  loyalty_points_redeemed Int        @default(0)
  tax                     Decimal    @default(0) @db.Decimal(10, 2)
  final_total             Decimal    @default(0) @db.Decimal(10, 2)
  cash_received           Decimal?   @db.Decimal(10, 2)
  payment_method          String?
  table_name              String?
  status                  SaleStatus @default(completed)
  created_at              DateTime   @default(now())
  tenant_id               Int

  tenant               Tenant               @relation(fields: [tenant_id], references: [id])
  customer             Customer?            @relation(fields: [customer_id], references: [id])
  cashier              User?                @relation("CashierSales", fields: [cashier_id], references: [id])
  shift                Shift?               @relation(fields: [shift_id], references: [id])
  coupon               Coupon?              @relation(fields: [coupon_id], references: [id])
  sale_items           SaleItem[]
  sale_payments        SalePayment[]
  sale_returns         SaleReturn[]
  coupon_usages        CouponUsage[]
  loyalty_transactions LoyaltyTransaction[]

  @@map("sales")
}

model SalePayment {
  id         Int      @id @default(autoincrement())
  sale_id    Int
  method     String
  amount     Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now())

  sale Sale @relation(fields: [sale_id], references: [id])

  @@map("sale_payments")
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  sale_id    Int
  product_id Int
  quantity   Int
  price      Decimal @db.Decimal(10, 2)

  sale              Sale             @relation(fields: [sale_id], references: [id])
  product           Product          @relation(fields: [product_id], references: [id])
  sale_return_items SaleReturnItem[]

  @@map("sale_items")
}

model SaleReturn {
  id            Int      @id @default(autoincrement())
  sale_id       Int
  return_date   DateTime @default(now())
  reason        String?
  refund_amount Decimal  @db.Decimal(10, 2)

  sale              Sale             @relation(fields: [sale_id], references: [id])
  sale_return_items SaleReturnItem[]

  @@map("sale_returns")
}

model SaleReturnItem {
  id           Int     @id @default(autoincrement())
  return_id    Int
  sale_item_id Int
  product_id   Int
  quantity     Int
  price        Decimal @db.Decimal(10, 2)

  sale_return SaleReturn @relation(fields: [return_id], references: [id])
  sale_item   SaleItem   @relation(fields: [sale_item_id], references: [id])
  product     Product    @relation(fields: [product_id], references: [id])

  @@map("sale_return_items")
}

model Shift {
  id            Int         @id @default(autoincrement())
  cashier_id    Int
  opening_cash  BigInt
  closing_cash  BigInt?
  expected_cash BigInt?
  variance      BigInt?
  start_time    DateTime    @default(now())
  end_time      DateTime?
  status        ShiftStatus @default(open)
  notes         String?
  is_deleted    Boolean     @default(false)
  tenant_id     Int

  cashier              User                @relation(fields: [cashier_id], references: [id])
  tenant               Tenant              @relation(fields: [tenant_id], references: [id])
  sales                Sale[]
  shift_cash_movements ShiftCashMovement[]
  expenses             Expense[]

  @@map("shifts")
}

model ShiftCashMovement {
  id         Int              @id @default(autoincrement())
  shift_id   Int
  type       CashMovementType
  amount     BigInt
  reason     String?
  created_at DateTime         @default(now())

  shift Shift @relation(fields: [shift_id], references: [id])

  @@map("shift_cash_movements")
}

model Settings {
  id                     Int       @id @default(autoincrement())
  tenant_id              Int       @unique
  store_name             String?
  store_address          String?
  store_phone            String?
  store_email            String?
  store_gstin            String?
  currency               String    @default("PKR")
  tax_rate               Decimal   @default(5) @db.Decimal(5, 2)
  items_per_page         Int       @default(10)
  theme                  String    @default("dark")
  invoice_prefix         String    @default("INV")
  low_stock_alert        Int       @default(5)
  receipt_logo           String?
  receipt_footer_message String?
  receipt_show_tax       Boolean   @default(false)
  receipt_show_donation  Boolean   @default(false)
  loyalty_rate           Decimal   @default(100) @db.Decimal(10, 2)
  loyalty_min_redeem     Int       @default(100)
  loyalty_max_percent    Int       @default(30)
  mode                   StoreMode @default(retail)

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("settings")
}

model Coupon {
  id              Int        @id @default(autoincrement())
  code            String
  type            CouponType
  value           Decimal    @db.Decimal(10, 2)
  min_order_value Decimal    @default(0) @db.Decimal(10, 2)
  usage_limit     Int?
  used_count      Int        @default(0)
  expiry_date     DateTime?
  is_active       Boolean    @default(true)
  is_deleted      Boolean    @default(false)
  created_at      DateTime   @default(now())
  tenant_id       Int

  tenant        Tenant        @relation(fields: [tenant_id], references: [id])
  sales         Sale[]
  coupon_usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        Int      @id @default(autoincrement())
  coupon_id Int
  sale_id   Int
  discount  Decimal  @db.Decimal(10, 2)
  used_at   DateTime @default(now())

  coupon Coupon @relation(fields: [coupon_id], references: [id])
  sale   Sale   @relation(fields: [sale_id], references: [id])

  @@map("coupon_usages")
}

model LoyaltyTransaction {
  id            Int           @id @default(autoincrement())
  customer_id   Int
  sale_id       Int?
  type          LoyaltyTxType
  points        Int
  balance_after Int
  note          String?
  created_at    DateTime      @default(now())

  customer Customer @relation(fields: [customer_id], references: [id])
  sale     Sale?    @relation(fields: [sale_id], references: [id])

  @@map("loyalty_transactions")
}

model Notification {
  id            Int      @id @default(autoincrement())
  product_id    Int
  product_name  String
  current_stock Int
  threshold     Int
  is_read       Boolean  @default(false)
  created_at    DateTime @default(now())
  tenant_id     Int

  product Product @relation(fields: [product_id], references: [id])
  tenant  Tenant  @relation(fields: [tenant_id], references: [id])

  @@map("notifications")
}

model Supplier {
  id         Int            @id @default(autoincrement())
  name       String
  phone      String?
  email      String?
  address    String?
  status     SupplierStatus @default(active)
  notes      String?
  is_deleted Boolean        @default(false)
  created_at DateTime       @default(now())
  tenant_id  Int

  tenant          Tenant          @relation(fields: [tenant_id], references: [id])
  supplier_items  SupplierItem[]
  purchase_orders PurchaseOrder[]

  @@map("suppliers")
}

model SupplierItem {
  id             Int     @id @default(autoincrement())
  supplier_id    Int
  product_id     Int
  unit_cost      Decimal @default(0) @db.Decimal(10, 2)
  lead_time_days Int     @default(0)
  is_primary     Boolean @default(false)

  supplier Supplier @relation(fields: [supplier_id], references: [id])
  product  Product  @relation(fields: [product_id], references: [id])

  @@unique([supplier_id, product_id])
  @@map("supplier_items")
}

model PurchaseOrder {
  id            Int                 @id @default(autoincrement())
  po_number     Int                 @default(0)
  supplier_id   Int
  status        PurchaseOrderStatus @default(draft)
  notes         String?
  expected_date DateTime?
  created_by    Int
  created_at    DateTime            @default(now())
  tenant_id     Int

  tenant               Tenant              @relation(fields: [tenant_id], references: [id])
  supplier             Supplier            @relation(fields: [supplier_id], references: [id])
  purchase_order_items PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                Int     @id @default(autoincrement())
  po_id             Int
  product_id        Int
  quantity_ordered  Int
  quantity_received Int     @default(0)
  unit_cost         Decimal @default(0) @db.Decimal(10, 2)

  purchase_order PurchaseOrder @relation(fields: [po_id], references: [id])
  product        Product       @relation(fields: [product_id], references: [id])

  @@map("purchase_order_items")
}

model Expense {
  id             Int                  @id @default(autoincrement())
  title          String
  amount         Decimal              @db.Decimal(10, 2)
  category       ExpenseCategory
  payment_method ExpensePaymentMethod @default(cash)
  notes          String?
  expense_date   DateTime             @db.Date
  created_by     Int
  shift_id       Int?
  is_deleted     Boolean              @default(false)
  created_at     DateTime             @default(now())
  tenant_id      Int

  tenant Tenant  @relation(fields: [tenant_id], references: [id])
  user   User    @relation(fields: [created_by], references: [id])
  shift  Shift?  @relation(fields: [shift_id], references: [id])

  @@map("expenses")
}

model RestaurantTable {
  id            Int         @id @default(autoincrement())
  name          String
  capacity      Int         @default(4)
  status        TableStatus @default(available)
  floor_section String      @default("Main")
  is_deleted    Boolean     @default(false)
  created_at    DateTime    @default(now())
  tenant_id     Int

  tenant Tenant            @relation(fields: [tenant_id], references: [id])
  orders RestaurantOrder[]

  @@map("restaurant_tables")
}

model RestaurantOrder {
  id          Int         @id @default(autoincrement())
  table_id    Int
  waiter_id   Int?
  waiter_name String?
  pax         Int         @default(1)
  status      OrderStatus @default(open)
  notes       String?
  created_at  DateTime    @default(now())
  tenant_id   Int

  tenant      Tenant                @relation(fields: [tenant_id], references: [id])
  table       RestaurantTable       @relation(fields: [table_id], references: [id])
  waiter      User?                 @relation(fields: [waiter_id], references: [id])
  items       RestaurantOrderItem[]
  kots        Kot[]
  bill_splits BillSplit[]

  @@map("restaurant_orders")
}

model RestaurantOrderItem {
  id         Int        @id @default(autoincrement())
  order_id   Int
  product_id Int
  kot_id     Int?
  quantity   Int        @default(1)
  unit_price Decimal    @db.Decimal(10, 2)
  notes      String?
  status     ItemStatus @default(pending)
  created_at DateTime   @default(now())

  order   RestaurantOrder @relation(fields: [order_id], references: [id])
  product Product         @relation(fields: [product_id], references: [id])
  kot     Kot?            @relation(fields: [kot_id], references: [id])

  @@map("restaurant_order_items")
}

model Kot {
  id         Int       @id @default(autoincrement())
  order_id   Int
  kot_number String
  status     KotStatus @default(pending)
  printed_at DateTime  @default(now())

  order RestaurantOrder       @relation(fields: [order_id], references: [id])
  items RestaurantOrderItem[]

  @@map("kots")
}

model BillSplit {
  id           Int       @id @default(autoincrement())
  order_id     Int
  split_type   SplitType
  person_label String
  amount       Decimal   @db.Decimal(10, 2)
  items_json   String?
  paid         Boolean   @default(false)
  created_at   DateTime  @default(now())

  order RestaurantOrder @relation(fields: [order_id], references: [id])

  @@map("bill_splits")
}
